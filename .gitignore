# ===================
# AIS Project .gitignore
# ===================

# OS files
.DS_Store
Thumbs.db

# Environment & Credentials - NEVER COMMIT!
.env
.env.local
.env.*.local
*.pem
credentials.json
secrets.yaml

# ===================
# Node.js / Next.js
# ===================
node_modules/
.next/
out/
.cache/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ===================
# Python / CV Module
# ===================
venv/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# CV Data (large files, generated locally)
ais-cv/data/photos/
ais-cv/data/logs/
ais-cv/*.jpg
ais-cv/*.png

# CV Config with credentials
ais-cv/config/settings.yaml

# ===================
# IDE & Editors
# ===================
.vscode/
.idea/
*.swp
*.swo
*~

# ===================
# BMAD - Keep structure, ignore generated
# ===================
# Keep _bmad folder but ignore any temp files
_bmad-output/*.tmp

# ===================
# Testing
# ===================
coverage/
.nyc_output/
.pytest_cache/
htmlcov/

# ===================
# Build artifacts
# ===================
*.zip
*.tar.gz
*.tgz
