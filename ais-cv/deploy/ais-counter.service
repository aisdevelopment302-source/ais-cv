[Unit]
Description=AIS Plate Counter Service
Documentation=https://github.com/your-repo/ais
After=network.target network-online.target
Wants=network-online.target

[Service]
Type=simple
User=adityajain
Group=adityajain
WorkingDirectory=/home/adityajain/AIS/ais-cv
Environment=PATH=/home/adityajain/AIS/ais-cv/venv/bin:/usr/bin:/bin
ExecStart=/home/adityajain/AIS/ais-cv/venv/bin/python scripts/run_counter.py
Restart=always
RestartSec=10
StandardOutput=append:/home/adityajain/AIS/ais-cv/data/logs/counter.log
StandardError=append:/home/adityajain/AIS/ais-cv/data/logs/counter-error.log

# Give time for camera connection
TimeoutStartSec=60

# Watchdog - restart if no response
WatchdogSec=300

[Install]
WantedBy=multi-user.target
