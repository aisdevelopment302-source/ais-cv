{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "rewrites": [
      {
        "source": "/",
        "destination": "/index.html"
      },
      {
        "source": "/history",
        "destination": "/history.html"
      },
      {
        "source": "/day",
        "destination": "/day.html"
      }
    ]
  }
}
